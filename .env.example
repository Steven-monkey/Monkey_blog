# ═══════════════════════════════════════════════════════════════
# 环境变量配置模板
# 复制此文件为 .env 并填入你的实际密钥
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── 博客作者名（首页 Hero 区域显示） ──────────────────────────
AUTHOR_NAME=Monkey

# ── 大模型 API（文本生成：箴言、AI搜索、阅读助手等共用） ──────
LLM_API_KEY=你的LLM密钥
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_API_URL=https://api.siliconflow.cn/v1

# ── 生图 API（智慧箴言背景图） ──────────────────────────────
IMAGE_API_KEY=你的生图密钥
IMAGE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
IMAGE_MODEL=doubao-seedream-4-5-251128

# ── 生图尺寸（主尺寸 + 回退尺寸） ──────────────────────────
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1920
IMAGE_FALLBACK_WIDTH=1440
IMAGE_FALLBACK_HEIGHT=2560

# ── 超时配置（秒） ────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=45
LLM_HTTP_TIMEOUT_SECONDS=30
IMAGE_HTTP_TIMEOUT_SECONDS=60
DOWNLOAD_HTTP_TIMEOUT_SECONDS=45

# ── GitHub 笔记同步（可选）─────────────────────────────────
# 配置后在启动时自动从 GitHub 仓库拉取 Markdown 笔记
GITHUB_REPO=owner/repo-name
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_PATH=content/notes
GITHUB_BRANCH=main

# ── Flask 服务器 ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
HOST=0.0.0.0
PORT=8080
